#!/bin/sh /etc/rc.common
# Re-apply active vpn-switch TOML profile at boot

START=99
STOP=10
USE_PROCD=0

start_service() {
	[ -x /usr/bin/vpn-switch ] || return 0
	local active
	active=$(uci -q get vpn-switch.settings.active 2>/dev/null || echo direct)
	/usr/bin/vpn-switch apply "$active" >/tmp/vpn-switch-boot.log 2>&1 || true
}

start() {
	start_service
}

stop() {
	[ -x /usr/bin/vpn-switch ] || return 0
	/usr/bin/vpn-switch teardown >/dev/null 2>&1 || true
}

restart() {
	stop
	start
}

boot() {
	start
}
